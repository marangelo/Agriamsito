# ────────────────────────────────────
# MySQL Database
# ────────────────────────────────────
DB_HOST=mysql_container_name
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=platinum_showcase

# ────────────────────────────────────
# Steam Web API
# ────────────────────────────────────
STEAM_API_KEY=your_steam_api_key_here
STEAM_USER_ID=your_steam_64bit_id_here

# ────────────────────────────────────
# Sync protection (opcional)
# ────────────────────────────────────
# Si se define, el endpoint POST /api/sync-steam requerira
# el header "x-sync-secret" o query param "?secret=..."
# Ademas tiene rate limit de 5 minutos entre syncs por IP.
# SYNC_SECRET=tu_clave_secreta
