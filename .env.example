# ────────────────────────────────────
# MySQL Database
# ────────────────────────────────────
# Si MySQL corre en otro contenedor Docker en la misma red,
# usa el nombre del contenedor como host (ej: mysql_container_name)
# Si corre en el host (localhost), usa host.docker.internal (Win/Mac)
# o la IP del host (Linux: network_mode: host o IP directa)
DB_HOST=mysql_container_name
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=platinum_showcase

# ────────────────────────────────────
# Steam Web API
# ────────────────────────────────────
STEAM_API_KEY=your_steam_api_key_here
STEAM_USER_ID=your_steam_64bit_id_here
